<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Cubase.Macro.Mobile.Nav.NavPage"
             BackgroundColor="#1E1E1E"
             Title="Cubase Mobile">
    <Grid VerticalOptions="Center" 
          HorizontalOptions="Center">


        <VerticalStackLayout Spacing="20">
            <Button x:Name="MidiConfiguration" 
                    Text="Configuration" 
                    IsEnabled="True"
                    BackgroundColor="DeepSkyBlue"
                    TextColor="Black"
                    WidthRequest="200" />            
            <Button x:Name="MidiCommand" 
                    Text="Midi Commands" 
                    IsEnabled="False"
                    WidthRequest="200" />
            <Button x:Name="Lyrics" 
                    Text="Lyrics" 
                    IsEnabled="False"
                    WidthRequest="200" />
            <Button x:Name="RetryConnection" 
                    Text="Retry Connection" 
                    IsVisible="False"
                    WidthRequest="200" />
            <Label Text="Checking Midi Connection .." x:Name="Message" TextColor="Yellow" FontSize="Header"></Label>
        </VerticalStackLayout>

    </Grid>
</ContentPage>